# ══════════════════════════════════════════════════
# ModernVPS AI Layer — Configuration
# Path: /etc/modernvps/ai.conf
# chmod 600 /etc/modernvps/ai.conf
# ══════════════════════════════════════════════════

# ── Provider ───────────────────────────────────────
# Hiện tại chỉ hỗ trợ: anthropic
AI_PROVIDER="anthropic"

# ── Claude API ─────────────────────────────────────
# Lấy tại: https://console.anthropic.com
ANTHROPIC_API_KEY=""

# Model: dùng haiku cho real-time (rẻ, nhanh)
# claude-haiku-4-5      → ~$0.001/1K tokens  (khuyến nghị)
# claude-sonnet-4-5     → ~$0.003/1K tokens  (phân tích sâu hơn)
AI_MODEL="claude-haiku-4-5"

# ── Feature Toggle ─────────────────────────────────
# Tắt toàn bộ AI layer mà không cần sửa code
AI_ENABLED="true"

# ── Limits ─────────────────────────────────────────
# Timeout mỗi HTTP call đến Claude API (giây)
AI_TIMEOUT=15

# Số dòng log tối đa gửi lên AI (giảm token cost)
AI_LOG_LINES=50

# Max tokens cho response của Claude
AI_MAX_TOKENS=800

# ── Rate Limiting ──────────────────────────────────
# Số lần gọi AI tối đa mỗi giờ (tránh spam API khi loop)
AI_RATE_LIMIT=20

# File lưu rate limit counter (tự tạo)
AI_RATE_LIMIT_FILE="/tmp/.modernvps_ai_rl"
